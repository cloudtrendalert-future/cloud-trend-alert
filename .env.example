NODE_ENV=production
TZ=UTC
BOT_TOKEN=your_telegram_bot_token
REQUIRED_CHANNEL_ID=@your_required_channel
REQUIRED_CHANNEL_USERNAME=your_required_channel
ADMIN_IDS=123456789
PREMIUM_USER_IDS=
ALLOWED_GROUP_IDS=
DATA_DIR=./data
MAX_CONCURRENT_SCANS=2
SCAN_FREE_DAILY_QUOTA=3
COOLDOWN_SCAN_SECONDS=120
COOLDOWN_SCAN_PAIR_SECONDS=60
COOLDOWN_SCAN_PAIR_TF_SECONDS=30
MANUAL_SCORE_THRESHOLD=80
AUTO_SCORE_THRESHOLD=85
AUTO_MAX_SENDS_PER_DAY=24
AUTO_CRONS=*/5 * * * *
RETENTION_DAYS=60
KLINES_CACHE_TTL_SECONDS=180
MARKETDATA_TIMEOUT_MS=12000
LOG_LEVEL=info
